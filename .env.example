# OmanX environment variables
#
# For local development with `node server.js`, copy this file to:
#   .env

# === Required ===
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# === Optional ===
ANTHROPIC_MODEL=claude-sonnet-4-6
NODE_ENV=development
PORT=3000

# Web search (Tavily) — enables live lookups from official gov sources on compliance queries
TAVILY_API_KEY=tvly-your_key_here

# Persistent rate limits in production. Without these, production chat requests
# fail closed instead of using per-instance memory limits.
UPSTASH_REDIS_REST_URL=https://your-upstash-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_rest_token

# Daily message limits. Anonymous preview quota is keyed by browser session hash,
# with a client IP hash fallback. Signed-in quota follows the Supabase user id.
RATE_LIMIT_ANONYMOUS_DAILY_MAX=3
RATE_LIMIT_AUTHENTICATED_DAILY_MAX=50

# Canonical public app URL used for OAuth redirects. Set this to the production
# domain so Google sign-in returns to OmanX instead of a Vercel preview URL.
PUBLIC_SITE_URL=https://omanx.org

# Supabase Auth. Enable Google provider and email OTP in Supabase Auth, then add
# your production + local callback URLs in the Supabase dashboard. For fully
# branded Google account chooser copy, configure a Supabase custom Auth domain.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_or_anon_key

# Signed-in image uploads
IMAGE_UPLOAD_MAX_COUNT=1
IMAGE_UPLOAD_MAX_BYTES=3145728
