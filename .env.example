# OmanX environment variables
#
# For local development with `node server.js`, copy this file to:
#   .env

# === Required ===
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# === Optional ===
ANTHROPIC_MODEL=claude-sonnet-4-6
NODE_ENV=development
PORT=3000

# Web search (Tavily) — enables live lookups from official gov sources on compliance queries
TAVILY_API_KEY=tvly-your_key_here

# Persistent rate limits in production. Without these, serverless instances fall back
# to in-memory limits that can reset when the function instance changes.
UPSTASH_REDIS_REST_URL=https://your-upstash-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_rest_token

# Anonymous rate limits. Production should use Upstash so Vercel instances share
# quota state. Anonymous quota is keyed by client IP hash when available.
RATE_LIMIT_DAILY_MAX=20

# Canonical public app URL used for OAuth redirects. Set this to the production
# domain so Google sign-in returns to OmanX instead of a Vercel preview URL.
PUBLIC_SITE_URL=https://omanx.org

# Google OAuth through Supabase. Enable Google provider in Supabase Auth and add
# your production + local callback URLs in the Supabase dashboard. Set Supabase
# project/Auth branding to "OmanX" so Google does not show only the project ref.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_or_anon_key

# Signed-in image uploads
IMAGE_UPLOAD_MAX_COUNT=1
IMAGE_UPLOAD_MAX_BYTES=3145728
