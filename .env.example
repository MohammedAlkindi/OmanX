# OmanX environment variables
#
# For local development with `node server.js`, this project loads env vars
# from `config/.env` (see config/env.js). You can copy this file there:
#   cp .env.example config/.env

# === Required API keys ===
OPENAI_API_KEY=your_openai_api_key_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# === Required service configuration ===
SUPABASE_URL=https://your-project-ref.supabase.co
APP_BASE_URL=http://localhost:3000
# AUTH_REDIRECT_URL must exactly match an entry in Supabase → Authentication → URL Configuration → Redirect URLs.
# Local:      http://localhost:3000/workspace
# Production: https://www.omanx.org/workspace
AUTH_REDIRECT_URL=http://localhost:3000/workspace

# === Optional runtime settings ===
OPENAI_MODEL=gpt-4o-mini
NODE_ENV=development
PORT=3000
