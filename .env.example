# OmanX environment variables
#
# For local development with `node server.js`, copy this file to:
#   config/.env

# === Required API keys ===
OPENAI_API_KEY=your_openai_api_key_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# === Required service configuration ===
SUPABASE_URL=https://your-project-ref.supabase.co
APP_BASE_URL=https://www.omanx.org
AUTH_REDIRECT_URL=https://www.omanx.org/workspace

# === Optional runtime settings ===
# Optional: not used by current codepaths, keep empty unless needed for future server-side admin flows.
SUPABASE_SERVICE_ROLE_KEY=
OPENAI_MODEL=gpt-4o-mini
NODE_ENV=development
PORT=3000
