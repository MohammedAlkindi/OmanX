{
  "version": 2,
  "functions": {
    "api/*.js": {
      "maxDuration": 10
    }
  },
  "routes": [
    {
      "src": "^/api/(chat|health|ready|metrics)$",
      "dest": "/api/$1.js"
    },
    {
      "src": "^/(chat|health|ready|metrics)$",
      "dest": "/api/$1.js"
    },
    {
      "src": "^/assets/(.*)$",
      "dest": "/public/assets/$1"
    },
    {
      "src": "^/(app\\.js|styles\\.css)$",
      "dest": "/public/$1"
    },
    {
      "src": "^/$",
      "dest": "/public/index.html"
    },
    {
      "src": "^/(.*)$",
      "dest": "/public/$1"
    }
  ]
}
