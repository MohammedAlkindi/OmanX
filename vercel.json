{
  "version": 2,
  "outputDirectory": "public",
  "functions": {
    "api/**/*.js": {
      "maxDuration": 60
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/", "dest": "/chat.html" },
    { "src": "/(chat|workspace)", "status": 301, "headers": { "Location": "/" } },
    { "src": "/product", "dest": "/index.html" },
    { "src": "/product\\.html", "status": 301, "headers": { "Location": "/product" } },
    { "src": "/dashboard", "dest": "/dashboard.html" },
    { "src": "/system", "dest": "/system.html" },
    { "src": "/method", "dest": "/method.html" },
    { "src": "/vision", "dest": "/vision.html" },
    { "src": "/contact", "dest": "/contact.html" },
    { "src": "/examples", "dest": "/examples.html" },
    { "src": "/trust", "dest": "/trust.html" },
    { "src": "/collaboration", "dest": "/collaboration.html" },
    { "src": "/settings(\\.html)?", "status": 301, "headers": { "Location": "/" } },
    { "src": "/index\\.html", "status": 301, "headers": { "Location": "/product" } },
    { "src": "/(chat|system|method|vision|contact|examples|collaboration|trust|dashboard)\\.html", "status": 301, "headers": { "Location": "/$1" } },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
