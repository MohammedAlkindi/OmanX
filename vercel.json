{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "functions": {
    "server.js": {
      "includeFiles": [
        "index.html",
        "feedback.html",
        "styles.css",
        "app.js",
        "knowledge.json",
        "prompts.js",
        "router.js",
        "localResponder.js"
      ]
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "server.js"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
